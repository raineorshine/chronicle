<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.chronicle.extract</string>

	<key>ProgramArguments</key>
	<array>
		<string>__EXTRACT_BIN__</string>
	</array>

	<!-- Run once daily at 02:00 local time. -->
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>2</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<!-- Also run shortly after login so a freshly-booted Mac catches up. -->
	<key>RunAtLoad</key>
	<true/>

	<key>StandardOutPath</key>
	<string>__LOG_DIR__/extract.log</string>
	<key>StandardErrorPath</key>
	<string>__LOG_DIR__/extract.log</string>
</dict>
</plist>
